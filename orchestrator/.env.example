# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── WASM Worker nodes (comma-separated HTTP addresses) ────────────────────────
# Point these at one or more running wasm-worker-manager instances.
# Default dev port for wasm-worker-manager is 8000.
WORKER_ADDRS=http://localhost:8000

# ── Warm Pool ─────────────────────────────────────────────────────────────────
# Total pre-allocated worker-connection slots across all worker nodes.
POOL_CAPACITY=50

# ── Execution limits ──────────────────────────────────────────────────────────
# Per-request hard deadline (ms). The worker enforces its own CPU quota on top.
EXEC_TIMEOUT_MS=30000

# ── Redis (rate limiting + future pub/sub) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate limiting (token bucket per client IP) ────────────────────────────────
RATE_LIMIT_RPS=100    # sustained tokens per second
RATE_LIMIT_BURST=200  # max burst

# ── JWT authentication (leave blank to disable auth during development) ────────
JWT_SECRET=

# ── VFS Write-Behind (LibSQL / Turso) ─────────────────────────────────────────
# Leave blank to disable persistence (VFS snapshots are discarded).
LIBSQL_URL=libsql://your-db.turso.io?authToken=your-token-here

# How often to flush buffered VFS changes to the database (ms).
VFS_SYNC_INTERVAL_MS=500
